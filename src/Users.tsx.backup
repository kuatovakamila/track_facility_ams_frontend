import { useState, useEffect } from 'react';
import Layout from './components/Layout';
import { useAuth } from './contexts/AuthContext';

import ErrorState from './components/ErrorState';
import SkeletonLoader from './components/SkeletonLoader';
import { useAsyncState } from './hooks/useAsyncState';
import { usersApi } from './services/api';
import { mockSettingsCards, defaultSettingsState } from './data/mockData';
import type { User } from './types';

const Users = () => {
  const { user: currentUser } = useAuth();
  const [activeSettings, setActiveSettings] = useState<{[key: string]: boolean}>(defaultSettingsState);

  const { data: users, loading, error, execute: loadUsers } = useAsyncState<User[]>({
    initialData: []
  });

  // Fetch users from API
  const fetchUsers = async (): Promise<User[]> => {
    try {
      // Get users from the API with basic parameters
      const response = await usersApi.getUsers({
        limit: 50,  // Reasonable limit for the frontend
        skip: 0
      });
      
      // Логируем ответ от API
      console.log('API Response:', response);

      // Transform API response to match our frontend User interface
      const transformedUsers = response.map((user: any): User => {
        const transformedUser = {
          id: user.id,
          name: user.full_name || user.name || `Пользователь ${user.id}`,
          email: user.email || '',
          role: user.role || 'Работник',
          roleDescription: user.role_description || 'Описание...',
          age: user.age ? `${user.age} лет` : 'Не указан',
          hired: user.created_at ? new Date(user.created_at).toLocaleDateString('ru-RU', { 
            day: '2-digit', 
            month: '2-digit', 
            year: '2-digit' 
          }) : 'Не указано'
        };
        
        console.log('Transformed user:', transformedUser);
        return transformedUser;
      });

      return transformedUsers;
    } catch (error) {
      console.error('Failed to fetch users:', error);
      throw new Error('Не удалось загрузить список пользователей. Проверьте подключение к серверу.');
    }
  };

  useEffect(() => {
    loadUsers(fetchUsers);
  }, [loadUsers]);

  const settingsCards = mockSettingsCards;

  const toggleSetting = (settingId: string) => {
    setActiveSettings(prev => ({
      ...prev,
      [settingId]: !prev[settingId]
    }));
  };

  // Фильтруем список пользователей в зависимости от роли текущего пользователя
  console.log('=== DEBUG INFO ===');
  console.log('Current user role:', currentUser?.role);
  console.log('Current user object:', currentUser);
  console.log('All users from API:', users);
  console.log('Users array length:', users?.length);
  console.log('==================');
  
  // Получаем список пользователей в зависимости от роли
  const usersList = (users || []).filter(user => {
    // Выводим информацию для отладки
    console.log('=== FILTERING USER ===');
    console.log('User email:', user.email);
    console.log('User role:', user.role);
    console.log('Current user role:', currentUser?.role);
    console.log('Current user object:', currentUser);

    // Проверяем роль текущего пользователя
    const isCurrentUserAdmin = currentUser?.role === 'admin' || currentUser?.role === 'Admin' || currentUser?.role === 'Администратор';
    console.log('Is current user admin?', isCurrentUserAdmin);

    if (isCurrentUserAdmin) {
      console.log('✅ Admin sees all users - INCLUDING');
      // Временно показываем только админов для тестирования
      const isUserAdmin = user.role === 'admin' || user.role === 'Admin' || user.role === 'Администратор';
      console.log('Testing: showing only admins for admin user');
      return isUserAdmin;
    }

    // Проверяем роль пользователя в списке
    const isUserAdmin = user.role === 'admin' || user.role === 'Admin' || user.role === 'Администратор';
    const isCurrentUserOperator = currentUser?.role === 'operator' || currentUser?.role === 'Operator' || currentUser?.role === 'Оператор';
    
    console.log('Is user admin?', isUserAdmin);
    console.log('Is current user operator?', isCurrentUserOperator);

    // Оператор видит всех кроме админов
    if (isCurrentUserOperator) {
      const shouldInclude = !isUserAdmin;
      console.log('Operator filtering - should include?', shouldInclude);
      return shouldInclude;
    }

    // Остальные видят только свою роль
    const sameRole = user.role === currentUser?.role;
    console.log('Same role check:', sameRole);
    console.log('=== END FILTERING ===');
    return sameRole;
  });

  console.log('Final filtered users list:', usersList);

  // Show error state
  if (error) {
    return (
      <Layout title="Пользователи" hideDefaultBreadcrumbs>
        <ErrorState
          title="Ошибка загрузки пользователей"
          message={error.message}
          onRetry={() => loadUsers(fetchUsers)}
          className="min-h-[400px]"
        />
      </Layout>
    );
  }

  return (
    <Layout title="Пользователи" hideDefaultBreadcrumbs>
      <div className="relative bg-gradient-to-br from-[#014596] to-[#1e40af] h-80 -mx-8 -mt-8 overflow-hidden">
        {/* Волнистые линии */}
        <div className="absolute inset-0">
          <svg className="w-full h-full" viewBox="0 0 1200 300" preserveAspectRatio="none">
            <path 
              d="M0,120 C200,80 400,160 600,120 C800,80 1000,160 1200,120 L1200,300 L0,300 Z" 
              fill="rgba(255,255,255,0.15)"
            />
            <path 
              d="M0,180 C200,140 400,220 600,180 C800,140 1000,220 1200,180 L1200,300 L0,300 Z" 
              fill="rgba(255,255,255,0.1)"
            />
            <path 
              d="M0,220 C200,180 400,260 600,220 C800,180 1000,260 1200,220 L1200,300 L0,300 Z" 
              fill="rgba(255,255,255,0.05)"
            />
          </svg>
        </div>
        
        {/* Хлебные крошки и заголовок */}
        <div className="relative z-10 p-8">
          <div className="text-gray-300 text-sm mb-2">Страницы /</div>
          <h1 className="text-2xl font-bold text-white">Пользователи</h1>
        </div>
      </div>

      {/* Полупрозрачный белый блок с пользователями */}
      <div className="relative -mt-24 mx-4 lg:mx-8 mb-6">
        <div className="bg-white/80 backdrop-blur-sm rounded-3xl shadow-lg p-4 lg:p-6">
          {loading ? (
            <div className="space-y-4">
              {Array.from({ length: 3 }).map((_, index) => (
                <div key={index} className="animate-pulse">
                  <div className="h-4 bg-gray-200 rounded mb-2"></div>
                  <div className="h-3 bg-gray-200 rounded w-3/4"></div>
                </div>
              ))}
            </div>
          ) : (
                        <div className="space-y-4">
              {usersList.map((user) => (
                <div key={user.id} className="p-3 hover:bg-gray-50/50 rounded-xl transition-colors">
                  <div className="flex items-center space-x-4">
                    {/* Иконка пользователя */}
                    <div className="w-12 h-12 bg-[#014596] rounded-xl flex items-center justify-center flex-shrink-0">
                      <svg className="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                      </svg>
                    </div>
                    {/* Информация о пользователе */}
                    <div className="flex-1">
                      <div className="font-semibold text-gray-900 text-lg">{user.role}</div>
                      <div className="text-gray-500 text-sm">{user.email}</div>
                    </div>
                  </div>
                </div>
              ))}
          </div>
          )}
        </div>
      </div>

      {/* Настройки */}
      <div className="bg-white rounded-2xl sm:rounded-3xl shadow-lg p-4 sm:p-6 mb-4 sm:mb-6">
        <div className="mb-4 sm:mb-6">
          <h3 className="text-xl sm:text-2xl font-bold text-[#222B45] mb-2">Настройки</h3>
          <p className="text-gray-400 text-sm sm:text-base">Управление функциями системы</p>
        </div>
        
        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 sm:gap-6">
          {settingsCards.map((setting) => (
            <div key={setting.id} className="border border-gray-200 rounded-xl p-4 sm:p-6">
              <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-3">
                <div className="flex-1">
                  <h4 className="font-semibold text-gray-900 text-sm sm:text-base mb-1">{setting.title}</h4>
                  <p className="text-gray-500 text-xs sm:text-sm">{setting.description}</p>
                </div>
                <button
                  onClick={() => toggleSetting(setting.id)}
                  className={`relative inline-flex h-6 w-11 flex-shrink-0 cursor-pointer rounded-full border-2 border-transparent transition-colors duration-200 ease-in-out focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 ${
                    activeSettings[setting.id] ? 'bg-blue-600' : 'bg-gray-200'
                  }`}
                  role="switch"
                  aria-checked={activeSettings[setting.id]}
                  aria-label={`Toggle ${setting.title}`}
                >
                  <span
                    className={`pointer-events-none inline-block h-5 w-5 transform rounded-full bg-white shadow ring-0 transition duration-200 ease-in-out ${
                      activeSettings[setting.id] ? 'translate-x-5' : 'translate-x-0'
                    }`}
                  />
                </button>
              </div>
            </div>
          ))}
        </div>
          </div>
          
      {/* Пользователи */}
      <div className="bg-white rounded-2xl sm:rounded-3xl shadow-lg">
        <div className="p-4 sm:p-6 border-b border-gray-200">
          <div className="flex flex-col sm:flex-row sm:items-center sm:justify-between gap-4">
            <div>
              <h3 className="text-xl sm:text-2xl font-bold text-[#222B45]">Команда управления</h3>
              <p className="text-gray-400 text-sm sm:text-base">Пользователи и их роли</p>
            </div>
            <div className="flex flex-col sm:flex-row gap-2 sm:gap-4">
              <button 
                className="px-4 py-2 bg-[#014596] text-white rounded-lg text-sm font-medium hover:bg-blue-700 transition disabled:opacity-50"
                disabled={loading}
              >
                Добавить пользователя
              </button>
              <button 
                className="px-4 py-2 border border-gray-300 text-gray-700 rounded-lg text-sm font-medium hover:bg-gray-50 transition disabled:opacity-50"
                disabled={loading}
              >
                Экспорт
              </button>
            </div>
          </div>
        </div>

        {/* Mobile Cards View */}
        <div className="lg:hidden">
          {loading ? (
            <div className="p-4 space-y-4">
              {Array.from({ length: 4 }).map((_, index) => (
                <SkeletonLoader key={index} type="card" />
              ))}
            </div>
          ) : (
            <div className="p-4 space-y-4">
              {usersList.map((user) => (
              <div key={user.id} className="bg-gray-50 rounded-lg p-4">
                <div className="flex items-start justify-between mb-2">
                  <div>
                    <h4 className="font-semibold text-gray-900 text-sm">{user.name}</h4>
                    <p className="text-xs text-gray-500">{user.email}</p>
                  </div>
                  <span className={`inline-flex px-2 py-1 rounded-full text-xs font-medium ${
                    user.role === 'Администратор' 
                      ? 'bg-blue-100 text-blue-800' 
                      : 'bg-gray-100 text-gray-800'
                  }`}>
                    {user.role}
                  </span>
                </div>
                <div className="flex justify-between items-center text-xs text-gray-500 mb-2">
                  <span>{user.age}</span>
                  <span>Нанят: {user.hired}</span>
              </div>
                <p className="text-xs text-gray-500 mb-3">{user.roleDescription}</p>
                <div className="flex gap-2">
                  <button className="flex-1 text-blue-900 hover:text-blue-700 text-sm font-medium py-1 border border-blue-200 rounded">
                    Изменить
                  </button>
                  <button className="flex-1 text-red-900 hover:text-red-700 text-sm font-medium py-1 border border-red-200 rounded">
                    Удалить
                  </button>
                </div>
              </div>
            ))}
          </div>
          )}
        </div>

        {/* Desktop Table View */}
        <div className="hidden lg:block overflow-x-auto">
          {loading ? (
            <SkeletonLoader type="table" rows={6} />
          ) : (
            <table className="w-full">
              <thead className="bg-gray-50">
                <tr>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Пользователь</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Роль</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Возраст</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Нанят</th>
                  <th className="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Действия</th>
                </tr>
              </thead>
              <tbody className="bg-white divide-y divide-gray-200">
                {usersList.map((user) => (
                <tr key={user.id} className="hover:bg-gray-50">
                    <td className="px-6 py-4 whitespace-nowrap">
                    <div>
                          <div className="text-sm font-medium text-gray-900">{user.name}</div>
                          <div className="text-sm text-gray-500">{user.email}</div>
                      </div>
                    </td>
                    <td className="px-6 py-4 whitespace-nowrap">
                      <div>
                      <div className={`inline-flex px-2 py-1 rounded-full text-xs font-medium ${
                        user.role === 'Администратор' 
                          ? 'bg-blue-100 text-blue-800' 
                          : 'bg-gray-100 text-gray-800'
                      }`}>
                        {user.role}
                      </div>
                      <div className="text-sm text-gray-500 mt-1">{user.roleDescription}</div>
                      </div>
                    </td>
                  <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{user.age}</td>
                  <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-500">{user.hired}</td>
                  <td className="px-6 py-4 whitespace-nowrap text-sm text-gray-900 space-x-2">
                    <button className="text-blue-900 hover:text-blue-700 font-medium">
                        Изменить
                    </button>
                    <button className="text-red-900 hover:text-red-700 font-medium">
                      Удалить
                      </button>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )}
        </div>
      </div>
    </Layout>
  );
};

export default Users; 
